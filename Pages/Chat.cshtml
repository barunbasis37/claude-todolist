@page
@model ChatModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Chat";
    var token = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
}

<div class="chat-wrapper">
    <h1 class="chat-heading">Brainstorm your todos</h1>
    <p class="chat-subheading">Talk through what's on your list, get help prioritizing, or break a task down into steps.</p>

    <div id="chatLog" class="chat-log" aria-live="polite"></div>

    <form id="chatForm" class="chat-form">
        <textarea id="chatInput" class="chat-input" placeholder="What's on your mind?" rows="2" required></textarea>
        <button type="submit" class="btn btn-primary">Send</button>
    </form>

    <input type="hidden" id="requestToken" value="@token" />
</div>

@section Scripts {
    <script src="~/js/chat.js" asp-append-version="true"></script>
}
