<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TodoList</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TodoList.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">TodoList</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Chat">Chat</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Feedback">Feedback</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - TodoList - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    @{
        var showFeedbackFab = ViewData["HideFeedbackFab"] as bool? != true;
        var feedbackError = TempData["FeedbackError"] as string;
    }
    @if (showFeedbackFab)
    {
        <button type="button" id="feedbackFabBtn" class="feedback-fab" aria-label="Give feedback" aria-expanded="false" aria-controls="feedbackPopup">
            <span class="feedback-fab-icon">💬</span>
        </button>

        <div id="feedbackPopup" class="feedback-popup" role="dialog" aria-modal="true" aria-labelledby="feedbackPopupTitle" aria-hidden="true" inert data-feedback-open="@(feedbackError != null ? "true" : null)">
            <div class="feedback-popup-header">
                <h2 id="feedbackPopupTitle">Send Feedback</h2>
                <button type="button" id="feedbackPopupClose" class="feedback-popup-close" aria-label="Close">&times;</button>
            </div>
            @if (feedbackError != null)
            {
                <p class="feedback-popup-error" role="alert">@feedbackError</p>
            }
            <form method="post" asp-page="/Feedback" asp-page-handler="Add" class="feedback-popup-form">
                <input type="hidden" name="@nameof(FeedbackModel.ReturnUrl)" value="@(Context.Request.Path + Context.Request.QueryString)" />
                <input type="text" name="@nameof(FeedbackModel.Name)" class="feedback-input" placeholder="Your name" autocomplete="off" required />
                <textarea name="@nameof(FeedbackModel.Message)" class="feedback-textarea" placeholder="What's on your mind?" rows="3" required></textarea>
                <div class="feedback-rating-row">
                    <label for="feedbackPopupRating">Rating</label>
                    <select id="feedbackPopupRating" name="@nameof(FeedbackModel.Rating)" class="feedback-rating-select">
                        <partial name="_RatingOptions" />
                    </select>
                </div>
                <button type="submit" class="btn btn-primary feedback-popup-submit">Submit Feedback</button>
            </form>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
